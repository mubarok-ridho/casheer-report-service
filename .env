# Database Configuration - SATU DATABASE UNTUK SEMUA SERVICE
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_PASSWORD=pipinstallpython--upgrade
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/casheer_db?sslmode=disable

# Server Configuration
PORT=3003
APP_NAME=Casheer Auth Service

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_ORDER_COMPLETED=order_completed
RABBITMQ_QUEUE_EXPENSE_ADDED=expense_added

# Printer Configuration
PRINTER_DEFAULT_WIDTH=58mm
PRINTER_CHAR_PER_LINE_58=32
PRINTER_CHAR_PER_LINE_80=48